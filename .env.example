# =========================
# Core bot runtime (required)
# =========================
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# OAuth callback URL must match Discord Developer Portal exactly
DISCORD_REDIRECT_URI=https://your-domain.com/auth/discord/callback

# Session signing secret (min 32 chars)
SESSION_SECRET=replace_with_long_random_secret

# =========================
# Web runtime
# =========================
WEB_PORT=3000
WEB_URL=http://localhost:3000
NODE_ENV=production

# =========================
# Database / bootstrap
# =========================
# Primary guild fallback used only for transitional/legacy-safe flows.
GUILD_ID=your_primary_guild_id_here

# SQLite database file path
DATABASE_PATH=

# =========================
# Multi-tenant / superadmin
# =========================
MULTITENANT_ENABLED=true

# Root superadmin(s) by Discord ID
SUPERADMIN_DISCORD_ID=your_discord_user_id_here
# SUPERADMIN_DISCORD_IDS=123456789,987654321

# =========================
# Billing entitlement webhook
# =========================
# Secret expected in x-entitlement-secret header
ENTITLEMENT_WEBHOOK_SECRET=replace_with_random_webhook_secret

# =========================
# Blockchain provider essentials
# =========================
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_RPS=10

# Optional global fallback mock mode
MOCK_MODE=false
