# =========================
# Core bot runtime (required)
# =========================
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# OAuth callback URL must match Discord Developer Portal exactly
DISCORD_REDIRECT_URI=https://your-domain.com/auth/discord/callback
# Optional: comma-separated additional callback URLs for domain migration
# DISCORD_REDIRECT_URIS=https://old-domain.com/auth/discord/callback,https://new-domain.com/auth/discord/callback

# Session signing secret (min 32 chars)
SESSION_SECRET=replace_with_long_random_secret

# =========================
# Web runtime
# =========================
WEB_PORT=3000
WEB_URL=http://localhost:3000
# Optional: comma-separated additional portal origins kept live during migration
# WEB_URL_ALIASES=https://discordbot.solpranos.com,https://guildpilot.app
NODE_ENV=production
# Optional JSON payload size limit for webhook endpoints (Express body parser)
# WEBHOOK_BODY_LIMIT=2mb

# =========================
# Database / bootstrap
# =========================
# Primary guild fallback used only for transitional/legacy-safe flows.
GUILD_ID=your_primary_guild_id_here

# SQLite database file path
DATABASE_PATH=

# Automatic DB backups (hourly by default)
DB_BACKUP_ENABLED=true
# DB_BACKUP_INTERVAL_MINUTES=60
# DB_BACKUP_RETENTION_HOURS=72
# DB_BACKUP_KEEP_MIN=24
# DB_BACKUP_DIR=./database/backups
# DB_BACKUP_ON_STARTUP=true
# DB_BACKUP_STARTUP_DELAY_SECONDS=30

# =========================
# Multi-tenant / superadmin
# =========================
MULTITENANT_ENABLED=true

# Root superadmin(s) by Discord ID
SUPERADMIN_DISCORD_ID=your_discord_user_id_here
# SUPERADMIN_DISCORD_IDS=123456789,987654321

# =========================
# Billing entitlement webhook
# =========================
# Secret expected in x-entitlement-secret header
ENTITLEMENT_WEBHOOK_SECRET=replace_with_random_webhook_secret
# Optional support URL shown in portal billing cards/buttons
# BILLING_SUPPORT_URL=https://guildpilot.app/support
# Optional manage URL (supports placeholders: {GUILD_ID} {PLAN} {INTERVAL})
# BILLING_MANAGE_URL=https://guildpilot.app/billing/manage?guild={GUILD_ID}
# Provider-specific manage URLs (preferred over BILLING_MANAGE_URL when present)
# BILLING_STRIPE_MANAGE_URL=https://billing.stripe.com/p/login/xxxx?guild={GUILD_ID}
# BILLING_CRYPTO_MANAGE_URL=https://guildpilot.app/billing/crypto/manage?guild={GUILD_ID}

# Optional checkout URLs per provider/plan/interval.
# Naming pattern:
# BILLING_<PROVIDER>_CHECKOUT_<PLAN>_<INTERVAL>
# Example:
# BILLING_STRIPE_CHECKOUT_GROWTH_MONTHLY=https://buy.guildpilot.app/stripe/growth-monthly?guild={GUILD_ID}
# BILLING_STRIPE_CHECKOUT_GROWTH_YEARLY=https://buy.guildpilot.app/stripe/growth-yearly?guild={GUILD_ID}
# BILLING_STRIPE_CHECKOUT_PRO_MONTHLY=https://buy.guildpilot.app/stripe/pro-monthly?guild={GUILD_ID}
# BILLING_STRIPE_CHECKOUT_PRO_YEARLY=https://buy.guildpilot.app/stripe/pro-yearly?guild={GUILD_ID}
# BILLING_CRYPTO_CHECKOUT_GROWTH_MONTHLY=https://pay.guildpilot.app/crypto/growth-monthly?guild={GUILD_ID}
# BILLING_CRYPTO_CHECKOUT_GROWTH_YEARLY=https://pay.guildpilot.app/crypto/growth-yearly?guild={GUILD_ID}
# BILLING_CRYPTO_CHECKOUT_PRO_MONTHLY=https://pay.guildpilot.app/crypto/pro-monthly?guild={GUILD_ID}
# BILLING_CRYPTO_CHECKOUT_PRO_YEARLY=https://pay.guildpilot.app/crypto/pro-yearly?guild={GUILD_ID}

# Optional expiry sweep safety net (downgrades stale paid plans to Starter if billing period passed)
# BILLING_EXPIRY_SWEEP_ENABLED=true
# BILLING_EXPIRY_SWEEP_MS=3600000
# BILLING_EXPIRY_GRACE_MINUTES=1440

# =========================
# Blockchain provider essentials
# =========================
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_WEBHOOK_ID=your_webhook_id_here
# Optional: dedicated webhook id for tracked token activity (falls back to HELIUS_WEBHOOK_ID)
# HELIUS_TOKEN_WEBHOOK_ID=your_token_webhook_id_here
HELIUS_RPS=10

# Shared webhook secret for /api/webhooks/nft-activity and /api/webhooks/token-activity
NFT_ACTIVITY_WEBHOOK_SECRET=replace_with_random_webhook_secret
# Optional override just for token activity webhook auth (falls back to NFT_ACTIVITY_WEBHOOK_SECRET)
# TRACKED_TOKEN_WEBHOOK_SECRET=replace_with_random_webhook_secret

# Tracked token webhook retry tuning
# TRACKED_TOKEN_WEBHOOK_RETRY_MAX=3
# TRACKED_TOKEN_WEBHOOK_RETRY_BASE_MS=1500
# TRACKED_TOKEN_DURABLE_RETRY_MAX=24
# TRACKED_TOKEN_DURABLE_RETRY_BASE_MS=30000
# TRACKED_TOKEN_DURABLE_RETRY_MAX_DELAY_MS=1800000
# TRACKED_TOKEN_DURABLE_RETRY_BATCH_SIZE=20
# TRACKED_TOKEN_DURABLE_RETRY_SWEEP_SEC=30

# Optional global fallback mock mode
MOCK_MODE=false

# =========================
# Security hardening rollout flags (all optional; safe defaults shown)
# =========================
# Allow MOCK_MODE / tenant mock data in production (nft + token services).
# Leave UNSET in production. If MOCK_MODE=true in prod without this, the bot
# refuses to start (prevents fabricated balances from passing token gates).
# ALLOW_MOCK_IN_PROD=true

# Webhook abuse controls (Phase 1 / Fix B)
# WEBHOOK_RATE_MAX=600              # max webhook requests per window (per IP)
# WEBHOOK_RATE_WINDOW_MS=60000      # rate-limit window
# WEBHOOK_REPLAY_WINDOW_MS=60000    # in-memory replay short-circuit window
# WEBHOOK_MAX_BATCH=500             # max events per webhook request (0 = unlimited)
# USER_RATE_MAX=240                 # max /api/user/* requests per minute per user

# Module-identity enforcement (Phase 2 / Fix D): block a tenant from enabling a
# module its plan does not include. off (no change) -> monitor (log only) ->
# enforce (block). Roll out as off -> monitor (review logs) -> enforce.
# MODULE_IDENTITY_ENFORCE=off

# Per-tenant treasury config (Phase 2 / Fix E). When false (default), the
# treasury uses one global config exactly as before. Set true to give each
# guild its own isolated treasury config (closes cross-tenant overwrite).
# TREASURY_PER_TENANT=false

# Vault webhook per-guild secret + guild-match (Phase 2 / Fix F).
# off (default) = legacy single global secret. monitor = log what enforce would
# reject. enforce = require the target guild's own secret and reject events for
# other guilds. Provision a per-guild secret per vault tenant:
#   VAULT_WEBHOOK_SECRET_<GUILD_ID>=<random secret>
# VAULT_WEBHOOK_ENFORCE_GUILD_MATCH=off
# VAULT_WEBHOOK_SECRET_123456789012345678=replace_with_random_per_guild_secret

# --- Auth-path hardening (Phase 3) ---
# Session fixation protection (Fix G): regenerate the session id on login.
# Enabled by default; kill switch only.
# SESSION_FIXATION_PROTECTION=on

# Public return-origin trust (Fix I): by default the allowed OAuth return
# origins come ONLY from WEB_URL / WEB_URL_ALIASES / PUBLIC_WEB_ALLOWED_RETURN_ORIGINS,
# never from the request's X-Forwarded-Host. Set true ONLY if you must restore
# the legacy (insecure) request-origin trust.
# PUBLIC_WEB_TRUST_REQUEST_ORIGIN=false
# Optional explicit canonical base origin (preferred over WEB_URL for redirects)
# PUBLIC_WEB_BASE_URL=https://guildpilot.app

# CSRF synchronizer tokens (Fix J): off | monitor | enforce. Default monitor
# (checks + logs, never blocks). Flip to enforce only after the portal (which
# already attaches x-csrf-token) is deployed and monitor logs are clean.
# CSRF_MODE=monitor
