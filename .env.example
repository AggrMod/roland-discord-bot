DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

MOCK_MODE=true

SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

WEB_PORT=3000
WEB_URL=http://localhost:3000

PROPOSALS_CHANNEL_ID=your_channel_id_here
VOTING_CHANNEL_ID=your_voting_channel_id_here
RESULTS_CHANNEL_ID=your_results_channel_id_here
GOVERNANCE_LOG_CHANNEL_ID=your_governance_log_channel_id_here

# Discord OAuth2
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://discordbot.the-solpranos.com/auth/discord/callback
SESSION_SECRET=random_secret_string_here

# Role Configuration
# GUILD_ID is REQUIRED for role resync scheduler
# Trait-role mappings are configured in config/trait-roles.json
# Tier role IDs are configured in config/roles.json

# Feature Flags
HEIST_ENABLED=false
ROLE_RESYNC_ENABLED=true

# Micro-Transfer Verification
MICRO_VERIFY_ENABLED=false
VERIFICATION_RECEIVE_WALLET=your_verification_wallet_address_here
NFT_ACTIVITY_WEBHOOK_SECRET=optional_shared_secret_for_nft_webhook
VERIFY_REQUEST_TTL_MINUTES=15
POLL_INTERVAL_SECONDS=30
VERIFY_RATE_LIMIT_MINUTES=5
MAX_PENDING_PER_USER=1
