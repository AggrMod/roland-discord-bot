# =========================
# Core bot runtime (required)
# =========================
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# OAuth callback URL must match Discord Developer Portal exactly
DISCORD_REDIRECT_URI=https://your-domain.com/auth/discord/callback

# Session signing secret (min 32 chars)
SESSION_SECRET=replace_with_long_random_secret

# =========================
# Web runtime
# =========================
WEB_PORT=3000
WEB_URL=http://localhost:3000
NODE_ENV=production

# =========================
# Database / bootstrap
# =========================
# Used as fallback/default guild context in legacy flows.
# Keep set to your primary guild during transition.
GUILD_ID=your_primary_guild_id_here

# =========================
# Multi-tenant / superadmin
# =========================
# Keep false until you intentionally enable multitenant behavior.
MULTITENANT_ENABLED=false

# Root superadmin(s) by Discord ID
SUPERADMIN_DISCORD_ID=your_discord_user_id_here
# SUPERADMIN_DISCORD_IDS=123456789,987654321

# =========================
# Billing entitlement webhook
# =========================
# Secret expected in x-entitlement-secret header
ENTITLEMENT_WEBHOOK_SECRET=replace_with_random_webhook_secret

# =========================
# Blockchain providers
# =========================
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_RPS=10

# Optional global fallback mock mode (prefer tenant mock toggle in superadmin)
MOCK_MODE=false

# =========================
# Legacy optional channel fallbacks
# (tenant-scoped config should be used instead)
# =========================
PROPOSALS_CHANNEL_ID=
VOTING_CHANNEL_ID=
RESULTS_CHANNEL_ID=
GOVERNANCE_LOG_CHANNEL_ID=

# =========================
# Optional feature flags
# =========================
HEIST_ENABLED=false
ROLE_RESYNC_ENABLED=true

# =========================
# Optional micro-verify defaults
# (prefer tenant-scoped configuration)
# =========================
MICRO_VERIFY_ENABLED=false
VERIFICATION_RECEIVE_WALLET=
NFT_ACTIVITY_WEBHOOK_SECRET=
VERIFY_REQUEST_TTL_MINUTES=15
POLL_INTERVAL_SECONDS=30
VERIFY_RATE_LIMIT_MINUTES=5
MAX_PENDING_PER_USER=1
