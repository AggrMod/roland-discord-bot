{
  "root": true,
  "env": { "node": true, "browser": true, "es2022": true },
  "parserOptions": { "ecmaVersion": 2022 },
  "plugins": ["security"],
  "ignorePatterns": ["node_modules/", "Audit-09042026/"],
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "eqeqeq": "error",
    "security/detect-non-literal-regexp": "warn",
    "security/detect-possible-timing-attacks": "warn"
  }
}
